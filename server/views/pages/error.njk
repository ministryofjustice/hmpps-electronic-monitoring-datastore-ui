{% extends "../partials/layout-default.njk" %}

{% set heading = "Something went wrong" %}
{% set pageTitle = "Problem with the service" %}
{% set backUrl = "/" %}

{% block innerContent %}
  {% if stack %}
    <h2>{{ message }}</h2>
    <h3>{{ status }}</h3>
    <pre><code>{{ stack }}</code></pre>
  {% else %}
    <p class="govuk-body">Something went wrong. The error has been logged. Please try again</p>
  {% endif %}
{% endblock %}
