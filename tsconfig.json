{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "isolatedModules": true,
    "outDir": "./dist",
    "sourceMap": true,
    "noEmit": false,
    "allowJs": false,
    "strict": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "typeRoots": [
      "./server/@types",
      "./node_modules/@types"
    ]
  },
  "typeAcquisition": {
    "include": [
      "jest"
    ]
  },
  "exclude": [
    "node_modules",
    "assets",
    "integration_tests",
    "dist",
    "esbuild",
    "eslint.config.mjs",
    "cypress.config.ts",
    "cypress"
  ],
  "include": [
    "**/*.js",
    "**/*.ts",
    "assets/js/ems.mjs",
    "assets/js/utils/validateDateRange.mjs",
    "assets/js/utils/validateDate.mjs",
    "assets/js/components/emsSortableTable.mjs",
    "assets/js/components/emsSearchForm.mjs",
    "assets/js/components/emsDateFilter.mjs"
  ]
}
