{
  "$schema": "https://www.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "noEmit": true,
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "typeRoots": [
      "../../node_modules/@ministryofjustice/frontend-types"
    ]
  },
  "exclude": [],
  "include": [
    "**/*.js",
    "**/*.ts",
    "ems.mjs",
    "utils/validateDateRange.mjs",
    "utils/validateDate.mjs",
    "components/emsSortableTable.mjs",
    "components/emsSearchForm.mjs",
    "components/emsDateFilter.mjs"
  ]
}
