{
  "compilerOptions": {
    "target": "es2015",
    "noEmit": true,
    "lib": ["es2015", "dom"],
    "types": ["cypress", "express", "express-session"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "strictFunctionTypes": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["**/*.ts"]
}
